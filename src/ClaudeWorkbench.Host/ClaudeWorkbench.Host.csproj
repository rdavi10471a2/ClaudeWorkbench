    <ProjectReference Include="..\AIMonitor.Data\AIMonitor.Data.csproj" />
    <ProjectReference Include="..\AIMonitor.MSBuild\AIMonitor.MSBuild.csproj" />
    <ProjectReference Include="..\AIMonitor.Workflow\AIMonitor.Workflow.csproj" />
    <ProjectReference Include="..\AIMonitor.Indexing\AIMonitor.Indexing.csproj" />
    <ProjectReference Include="..\AIMonitor.Runtime\AIMonitor.Runtime.csproj" />
    <ProjectReference Include="..\AIMonitor.McpServer\AIMonitor.McpServer.csproj" />
  </ItemGroup>

</Project>
