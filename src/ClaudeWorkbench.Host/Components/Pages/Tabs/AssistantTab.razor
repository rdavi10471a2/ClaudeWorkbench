<div class="assistant-host">
    <div class="assistant-layout" @ref="assistantLayout">
        <div class="chat-composer" @ref="chatComposer">
            <div class="chat-composer-toolbar">
                <label class="composer-icon-btn @(uploading ? "busy" : null)"
                       title="@(uploading ? "Uploading..." : "Attach files")">
                    <InputFile class="attach-input" OnChange="OnFilesSelectedAsync" multiple disabled="@uploading" />
                    <RadzenIcon Icon="attach_file" />
                </label>
                <button type="button" class="composer-icon-btn"
                        title="Activity — tool calls and events for this run"
                        @onclick="OpenActivityAsync">
                    <RadzenIcon Icon="monitoring" />
                </button>
                <label class="composer-check"
                       title="Auto-approve claude-workbench edits for THIS thread only. The merge review still gates every write to watched source; New Thread turns it back off.">
                    <input type="checkbox" @bind="autoApprove" />
                    <span>Auto-approve</span>
                </label>
            </div>
            @if (uploadError is not null)
            {
                <div class="attach-error">@uploadError</div>
            }
            @if (attachments.Count > 0)
            {
                <div class="attach-chips">
                    @foreach (PendingAttachment attachment in attachments)
                    {
                        <span class="attach-chip" title="@attachment.Path">
                            <RadzenIcon Icon="description" />
                            <span class="attach-chip-name">@attachment.Name</span>
                            <button type="button"
                                    class="attach-chip-x"
                                    @onclick="() => RemoveAttachment(attachment)"
                                    aria-label="Remove attachment">&times;</button>
                        </span>
                    }
                </div>
            }
            @if (Working)
            {
                <div class="assistant-turn-activity" role="status" aria-live="polite">
                    <span class="assistant-turn-spinner" aria-hidden="true"></span>
                    <div class="assistant-turn-copy">
                        <strong>Thinking...</strong>
                        <span>Current turn is still running.</span>
                    </div>
                </div>
            }
            <textarea @ref="chatInput"
                      class="chat-composer-input"
                      @bind="draft"
                      @bind:event="oninput"
                      placeholder="Inspect the current workspace..."></textarea>
            <div class="chat-composer-actions">
                <span class="composer-actions-spacer" aria-hidden="true"></span>
                @if (Working)
                {
                    <RadzenButton Icon="stop"
                                  Text="Stop"
                                  Class="chat-send-button"
                                  ButtonStyle="ButtonStyle.Danger"
                                  Title="Interrupt the current turn"
                                  Click="@StopAsync" />
                }
                else
                {
                    <RadzenButton Icon="send"
                                  Text="Submit Turn"
                                  Class="chat-send-button"
                                  ButtonStyle="ButtonStyle.Primary"
                                  Title="Send this prompt to Claude"
                                  Click="@SubmitAsync"
                                  Disabled="@(string.IsNullOrWhiteSpace(draft) && attachments.Count == 0)" />
                }
            </div>
        </div>

        <div class="assistant-splitter"
             @ref="assistantSplitter"
             title="Drag to resize input and chat history"
             aria-hidden="true"></div>

        <section class="transcript-panel" @ref="transcriptPanel" aria-label="Chat history">
            <div class="transcript-header">
                <span>Chat History</span>
                <div class="transcript-actions">
                    <div class="usage-anchor">
                        <RadzenButton Icon="monitoring"
                                      Text="Usage"
                                      ButtonStyle="ButtonStyle.Light"
                                      Size="ButtonSize.Small"
                                      Title="Context-window fill and subscription usage"
                                      Click="@ToggleUsageAsync" />
                        @if (usageOpen)
                        {
                            <div class="usage-dropdown">
                                <div class="usage-head">
                                    <span>Usage</span>
                                    <button type="button" class="usage-close" @onclick="@(() => usageOpen = false)" aria-label="Close usage">&times;</button>
                                </div>
                                @if (usage is null || !usage.Available)
                                {
                                    <div class="usage-empty">Usage appears once a turn has run in this thread.</div>
                                }
                                else
                                {
                                    <div class="usage-block">
                                        <div class="usage-row"><span>Context</span><strong>@Pct(usage.ContextPercent) used</strong></div>
                                        <div class="usage-bar"><div class="usage-bar-fill" style="width:@BarWidth(usage.ContextPercent)"></div></div>
                                        @if (usage.FreeUntilCompactPercent is double free)
                                        {
                                            <div class="usage-note">@Pct(free) free until auto-compact</div>
                                        }
                                        @if (usage.ContextUsedTokens is long used && usage.ContextMaxTokens is long max)
                                        {
                                            <div class="usage-note">@used.ToString("N0") / @max.ToString("N0") tokens</div>
                                        }
                                    </div>
                                    <div class="usage-block">
                                        <div class="usage-row"><span>Weekly</span><strong>@Pct(usage.WeeklyPercent)</strong></div>
                                        @if (usage.WeeklyResetsAt is not null)
                                        {
                                            <div class="usage-note">resets @Reset(usage.WeeklyResetsAt)</div>
                                        }
                                        <div class="usage-row"><span>5-hour</span><strong>@Pct(usage.FiveHourPercent)</strong></div>
                                        @if (usage.FiveHourResetsAt is not null)
                                        {
                                            <div class="usage-note">resets @Reset(usage.FiveHourResetsAt)</div>
                                        }
                                        @if (usage.MonthlyPercent is not null)
                                        {
                                            <div class="usage-row"><span>Monthly overage</span><strong>@Pct(usage.MonthlyPercent)</strong></div>
                                        }
                                        @if (usage.PlanType is not null)
                                        {
                                            <div class="usage-note">plan: @usage.PlanType</div>
                                        }
                                    </div>
                                }
                                <button class="usage-refresh" type="button" @onclick="RefreshUsageAsync">Refresh</button>
                            </div>
                        }
                    </div>
                    <RadzenButton Icon="add_comment"
                                  Text="New Thread"
                                  ButtonStyle="ButtonStyle.Light"
                                  Size="ButtonSize.Small"
                                  Title="Start a fresh conversation (resets auto-approve)"
                                  Click="@NewThreadAsync"
                                  Disabled="@(Session.Status.Working)" />
                    <RadzenButton Icon="content_copy"
                                  Text="Copy"
                                  ButtonStyle="ButtonStyle.Light"
                                  Size="ButtonSize.Small"
                                  Title="Copy the transcript to the clipboard"
                                  Click="@CopyAsync"
                                  Disabled="@(!HasTranscript)" />
                    <RadzenButton Icon="open_in_new"
                                  Text="Pop Out"
                                  ButtonStyle="ButtonStyle.Light"
                                  Size="ButtonSize.Small"
                                  Title="Open the transcript in a new window"
                                  Click="@PopOutAsync"
                                  Disabled="@(!HasTranscript)" />
                </div>
            </div>
            <div class="transcript-view" @ref="transcriptView" role="log" aria-label="Chat history">
                <div class="transcript-body">
                    @if (!HasTranscript)
                    {
                        <div class="empty">
                            <div class="empty-icon">&#128172;</div>
                            <div>No messages yet. Ask Claude to inspect the watched solution.</div>
                        </div>
                    }
                    else
                    {
                        @foreach (TranscriptEntry entry in Session.Transcript)
                        {
                            @if (entry.Kind == TranscriptKind.User)
                            {
                                <div class="message user">
                                    <div class="message-header">
                                        <span class="message-meta">You</span>
                                        <div class="message-header-right">
                                            @if (!string.IsNullOrEmpty(entry.Time))
                                            {
                                                <span class="entry-time">@entry.Time</span>
                                            }
                                            <button type="button" class="message-copy" title="Copy this message"
                                                    @onclick="@(() => CopyMessageAsync(entry.Text))">
                                                <RadzenIcon Icon="content_copy" />
                                            </button>
                                        </div>
                                    </div>
                                    <div class="message-body">@entry.Text</div>
                                </div>
                            }
                            else if (entry.Kind == TranscriptKind.ToolCall)
                            {
                                <div class="tool-line">
                                    <span>&#8594; @entry.Text</span>
                                    @if (!string.IsNullOrEmpty(entry.Time))
                                    {
                                        <span class="entry-time">@entry.Time</span>
                                    }
                                </div>
                            }
                            else if (entry.Kind == TranscriptKind.Image)
                            {
                                <div class="message assistant">
                                    <div class="message-header">
                                        <span class="message-meta">Assistant</span>
                                        <div class="message-header-right">
                                            @if (!string.IsNullOrEmpty(entry.Time))
                                            {
                                                <span class="entry-time">@entry.Time</span>
                                            }
                                        </div>
                                    </div>
                                    <div class="message-body">
                                        <a href="@LocalFileUrl(entry.Text)" target="_blank" rel="noopener" title="@entry.Text">
                                            <img class="chat-inline-image" src="@LocalFileUrl(entry.Text)" alt="@System.IO.Path.GetFileName(entry.Text)" />
                                        </a>
                                    </div>
                                </div>
                            }
                            else
                            {
                                <div class="message assistant">
                                    <div class="message-header">
                                        <span class="message-meta">Assistant</span>
                                        <div class="message-header-right">
                                            @if (!string.IsNullOrEmpty(entry.Time))
                                            {
                                                <span class="entry-time">@entry.Time</span>
                                            }
                                            <button type="button" class="message-copy" title="Copy this message"
                                                    @onclick="@(() => CopyMessageAsync(entry.Text))">
                                                <RadzenIcon Icon="content_copy" />
                                            </button>
                                        </div>
                                    </div>
                                    <div class="message-body">@RenderMarkdown(entry.Text)</div>
                                </div>
                            }
                        }
                    }
                </div>
            </div>
        </section>

        <AgentActionModal />
    </div>
</div>
