@implements IDisposable
@inject IOperatorConsole Session

<div class="assistant">
    <div class="assistant-transcript">
        @foreach (TranscriptEntry entry in Session.Transcript)
        {
            <div class="assistant-line @(entry.Kind == TranscriptKind.ToolCall ? "line-tool" : "line-text")">
                @(entry.Kind == TranscriptKind.ToolCall ? $"→ {entry.Text}" : entry.Text)
            </div>
        }
    </div>
    <div class="assistant-input">
        <textarea @bind="prompt"
                  @bind:event="oninput"
                  rows="3"
                  placeholder="Ask Claude to work on the watched solution..."></textarea>
        <RadzenButton Text="Send"
                      Icon="send"
                      Click="@SendAsync"
                      Disabled="@(busy || string.IsNullOrWhiteSpace(prompt))" />
    </div>
</div>

@code {
    private string prompt = string.Empty;
    private bool busy;

    protected override void OnInitialized()
    {
        Session.Changed += OnChanged;
    }

    private void OnChanged()
    {
        InvokeAsync(StateHasChanged);
    }

    private async Task SendAsync()
    {
        busy = true;
        try
        {
            await Session.SendAsync(prompt);
            prompt = string.Empty;
        }
        finally
        {
            busy = false;
        }
    }

    public void Dispose()
    {
        Session.Changed -= OnChanged;
    }
}
