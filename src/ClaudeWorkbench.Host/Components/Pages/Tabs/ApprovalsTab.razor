<div class="approvals">
    @if (Approvals.PendingApprovals.Count == 0)
    {
        <div class="approvals-empty">No pending approvals. Mutating actions will pause here for review.</div>
    }
    else
    {
        @foreach (ApprovalRequest approval in Approvals.PendingApprovals)
        {
            <div class="gate-card">
                <div class="gate-head">
                    <span class="gate-tool">@approval.Tool</span>
                    @if (!string.IsNullOrWhiteSpace(approval.Target))
                    {
                        <span class="gate-file">@approval.Target</span>
                    }
                </div>
                <div class="gate-actions">
                    <RadzenButton Text="Allow"
                                  ButtonStyle="ButtonStyle.Success"
                                  Size="ButtonSize.Small"
                                  Click="@(() => ResolveAsync(approval.Id, true))" />
                    <RadzenButton Text="Deny"
                                  ButtonStyle="ButtonStyle.Danger"
                                  Size="ButtonSize.Small"
                                  Click="@(() => ResolveAsync(approval.Id, false))" />
                </div>
            </div>
        }
    }
</div>
