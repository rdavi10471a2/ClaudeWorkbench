@implements IDisposable
@inject IOperatorConsole Session

<div class="approvals">
    @if (Session.PendingApprovals.Count == 0)
    {
        <div class="approvals-empty">No pending approvals. Mutating actions will pause here for review.</div>
    }
    else
    {
        @foreach (ApprovalRequest approval in Session.PendingApprovals)
        {
            <div class="gate-card">
                <div class="gate-head">
                    <span class="gate-tool">@approval.Action</span>
                    @if (!string.IsNullOrWhiteSpace(approval.Target))
                    {
                        <span class="gate-file">@approval.Target</span>
                    }
                </div>
                <div class="gate-actions">
                    <RadzenButton Text="Allow"
                                  ButtonStyle="ButtonStyle.Success"
                                  Size="ButtonSize.Small"
                                  Click="@(() => ResolveAsync(approval.Id, true))" />
                    <RadzenButton Text="Deny"
                                  ButtonStyle="ButtonStyle.Danger"
                                  Size="ButtonSize.Small"
                                  Click="@(() => ResolveAsync(approval.Id, false))" />
                </div>
            </div>
        }
    }
</div>

@code {
    protected override void OnInitialized()
    {
        Session.Changed += OnChanged;
    }

    private void OnChanged()
    {
        InvokeAsync(StateHasChanged);
    }

    private async Task ResolveAsync(string approvalId, bool approve)
    {
        await Session.ResolveAsync(approvalId, approve);
    }

    public void Dispose()
    {
        Session.Changed -= OnChanged;
    }
}
