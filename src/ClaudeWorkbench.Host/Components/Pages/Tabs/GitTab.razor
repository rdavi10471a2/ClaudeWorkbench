@using ClaudeWorkbench.Host.Services

<div class="git-tab">
    @if (!Git.HasWorkspace)
    {
        <div class="git-empty">Select a watched solution to review its git history.</div>
    }
    else if (status is null)
    {
        <div class="git-empty">Loading git status…</div>
    }
    else if (!status.GitAvailable)
    {
        <div class="git-warning">
            <RadzenIcon Icon="warning" />
            <div class="git-warning-body">
                <strong>Git is not available.</strong>
                <div class="git-warning-detail">@status.Error</div>
                <div>Install git and make sure it is on PATH, then Refresh.</div>
            </div>
            <RadzenButton Icon="refresh" Text="Refresh" ButtonStyle="ButtonStyle.Light" Size="ButtonSize.Small" Disabled="@busy" Click="@ReloadAsync" />
        </div>
    }
    else if (!status.IsRepository)
    {
        <div class="git-panel">
            <p class="git-not-repo">The watched solution folder is not a git repository.</p>
            <p class="git-path">@Git.WatchedDirectory</p>
            <RadzenButton Icon="add" Text="Initialize Git repository" ButtonStyle="ButtonStyle.Primary" Disabled="@busy" Click="@InitAsync" />
            @if (resultMessage is not null)
            {
                <div class="git-result @(resultIsError ? "error" : "ok")">@resultMessage</div>
            }
        </div>
    }
    else
    {
        <div class="git-header">
            <div class="git-branchbar">
                <RadzenIcon Icon="account_tree" />
                <select class="git-branch-select" value="@status.Branch" @onchange="OnBranchSelected" disabled="@busy" title="Switch branch (confirms — changes the working tree)">
                    @if (status.Branch is not null && !branches.Contains(status.Branch))
                    {
                        <option value="@status.Branch">@status.Branch</option>
                    }
                    @foreach (string branch in branches)
                    {
                        <option value="@branch">@branch</option>
                    }
                </select>
                <RadzenButton Icon="add" Text="New" ButtonStyle="ButtonStyle.Light" Size="ButtonSize.Small" Disabled="@busy"
                              Click="@(() => newBranchOpen = !newBranchOpen)" Title="Create a new branch" />
                @if (status.Upstream is not null)
                {
                    <span class="git-upstream">→ @status.Upstream</span>
                }
                @if (status.Ahead > 0)
                {
                    <span class="git-badge ahead" title="Commits ahead of the remote">↑ @status.Ahead</span>
                }
                @if (status.Behind > 0)
                {
                    <span class="git-badge behind" title="Commits behind the remote">↓ @status.Behind</span>
                }
                @if (!status.HasRemote)
                {
                    <span class="git-badge noremote" title="No remote configured">no remote</span>
                }
                @if (status.HasChanges)
                {
                    <span class="git-badge dirty" title="Uncommitted changes in the working tree">@status.Changes.Count uncommitted</span>
                }
                else
                {
                    <span class="git-badge clean" title="Nothing to commit">clean</span>
                }
            </div>

            <div class="git-syncbar">
                <RadzenButton Icon="vertical_split"
                              Text="@(leftCollapsed ? "Show Panel" : "Hide Panel")"
                              ButtonStyle="ButtonStyle.Light" Size="ButtonSize.Small"
                              Click="@ToggleLeft" Title="Show or hide the review panel" />
                <RadzenButton Icon="refresh" Text="Refresh" ButtonStyle="ButtonStyle.Light" Size="ButtonSize.Small" Disabled="@busy" Click="@ReloadAsync" />
                <span class="git-bar-sep" aria-hidden="true"></span>
                @* Operator-only write actions. These call GitWorkspaceService directly (never
                   MCP); the outward/irreversible ones confirm first. *@
                <RadzenButton Icon="edit_note" Text="Commit" ButtonStyle="ButtonStyle.Light" Size="ButtonSize.Small"
                              Disabled="@(busy || !status.HasChanges)" Click="@OpenCommit" Title="Commit the working-tree changes" />
                <RadzenButton Icon="download" Text="Fetch" ButtonStyle="ButtonStyle.Light" Size="ButtonSize.Small" Disabled="@(busy || !status.HasRemote)" Click="@FetchAsync" />
                <RadzenButton Icon="south" Text="Pull" ButtonStyle="ButtonStyle.Light" Size="ButtonSize.Small" Disabled="@(busy || !status.HasRemote)" Click="@PullAsync" />
                <RadzenButton Icon="cloud_upload" Text="Push" ButtonStyle="ButtonStyle.Light" Size="ButtonSize.Small" Disabled="@(busy || !status.HasRemote)" Click="@PushAsync" />
                <RadzenButton Icon="merge" Text="Merge to main" ButtonStyle="ButtonStyle.Success" Size="ButtonSize.Small"
                              Disabled="@(busy || OnMain)" Click="@MergeToMainAsync"
                              Title="@(OnMain ? "Already on main" : "Merge this branch into main (requires a clean tree)")" />
            </div>
        </div>

        @if (newBranchOpen)
        {
            <div class="git-inline-form">
                <input class="git-inline-input" @bind="newBranchName" @bind:event="oninput" placeholder="new-branch-name" />
                <RadzenButton Icon="check" Text="Create" ButtonStyle="ButtonStyle.Primary" Size="ButtonSize.Small"
                              Disabled="@(busy || string.IsNullOrWhiteSpace(newBranchName))" Click="@CreateBranchAsync" />
                <RadzenButton Icon="close" Text="Cancel" ButtonStyle="ButtonStyle.Light" Size="ButtonSize.Small"
                              Click="@(() => { newBranchOpen = false; newBranchName = string.Empty; })" />
            </div>
        }

        @if (commitOpen)
        {
            <div class="git-inline-form commit">
                <textarea class="git-commit-message" @bind="commitMessage" @bind:event="oninput" placeholder="Commit message" rows="2"></textarea>
                <div class="git-inline-actions">
                    <RadzenButton Icon="check" Text="Commit all changes" ButtonStyle="ButtonStyle.Primary" Size="ButtonSize.Small"
                                  Disabled="@(busy || !status.HasChanges || string.IsNullOrWhiteSpace(commitMessage))" Click="@CommitAsync"
                                  Title="Stage everything (if nothing is staged) and commit." />
                    <RadzenButton Icon="close" Text="Cancel" ButtonStyle="ButtonStyle.Light" Size="ButtonSize.Small"
                                  Click="@(() => commitOpen = false)" />
                </div>
            </div>
        }

        @if (resultMessage is not null)
        {
            <div class="git-result @(resultIsError ? "error" : "ok")">@resultMessage</div>
        }

        <div class="git-body" @ref="gitBody">
            @if (!leftCollapsed)
            {
            <div class="git-left" @ref="gitLeft">
                @* --- Uncommitted changes (read-only review) --- *@
                <div class="git-group">
                    <div class="git-group-head">Uncommitted changes <span class="git-count">@status.Changes.Count</span></div>
                    @if (!status.HasChanges)
                    {
                        <div class="git-clean">Working tree clean.</div>
                    }
                    else
                    {
                        @foreach (GitChange change in status.Changes)
                        {
                            <div class="git-file @(IsWorkingSelected(change) ? "selected" : "")"
                                 @onclick="@(() => SelectWorkingFileAsync(change))">
                                <span class="git-file-code @(change.IsUntracked ? "untracked" : "unstaged")">@change.UnstagedCode</span>
                                <span class="git-file-path" title="@change.Path">@change.Path</span>
                            </div>
                        }
                    }
                </div>

                @* --- History (click-through commit review) --- *@
                <div class="git-group">
                    <div class="git-group-head">History</div>
                    <div class="git-history">
                        @foreach (GitCommit commit in history)
                        {
                            bool expanded = string.Equals(expandedCommit, commit.Hash, StringComparison.Ordinal);
                            <div class="git-commit-row @(expanded ? "expanded" : "")" @onclick="@(() => ToggleCommitAsync(commit))">
                                <RadzenIcon Icon="@(expanded ? "expand_more" : "chevron_right")" />
                                <code class="git-hash">@Short(commit.Hash)</code>
                                <span class="git-commit-subject" title="@commit.Subject">@commit.Subject</span>
                                <span class="git-commit-meta">@commit.Author · @commit.RelativeDate</span>
                            </div>
                            @if (expanded)
                            {
                                <div class="git-commit-files">
                                    @if (expandedFiles.Count == 0)
                                    {
                                        <div class="git-empty-sub">No file changes in this commit.</div>
                                    }
                                    else
                                    {
                                        @foreach (GitCommitFile file in expandedFiles)
                                        {
                                            <div class="git-file @(IsCommitFileSelected(commit, file) ? "selected" : "")"
                                                 @onclick:stopPropagation="true"
                                                 @onclick="@(() => SelectCommitFileAsync(commit, file))">
                                                <span class="git-file-code @CommitStatusClass(file)">@file.Status</span>
                                                <span class="git-file-path" title="@file.Path">@file.Path</span>
                                            </div>
                                        }
                                    }
                                </div>
                            }
                        }
                        @if (history.Count == 0)
                        {
                            <div class="git-empty-sub">No commits yet.</div>
                        }
                    </div>
                </div>
            </div>
            <div class="git-splitter" @ref="gitSplitter" title="Drag to resize" aria-hidden="true"></div>
            }

            <div class="git-right" @ref="gitRight">
                @if (diffContent is null)
                {
                    <div class="git-diff-empty">Select an uncommitted file or a file within a commit to review its diff.</div>
                }
                else
                {
                    <div class="git-diff-toolbar">
                        <span class="git-diff-title" title="@diffTitle">@diffTitle</span>
                    </div>
                    <div class="git-diff-view">
                        <DiffView OldText="@(diffContent.OldText)"
                                  NewText="@(diffContent.NewText)"
                                  OldLabel="@diffOldLabel"
                                  NewLabel="@diffNewLabel" />
                    </div>
                }
            </div>
        </div>
    }
</div>

@code {
    private static string CommitStatusClass(GitCommitFile file) => file.Status switch
    {
        'A' => "untracked",
        'D' => "deleted",
        _ => "unstaged",
    };
}
