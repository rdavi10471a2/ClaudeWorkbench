@page "/"
@implements IDisposable
@inject SidecarEventStream Stream

@* Thin shell only: command bar + tab host. All behaviour lives in the per-tab
   components (AssistantTab / ApprovalsTab / ActivityTab). No orchestration here. *@

<div class="wb-shell">
    <header class="wb-topbar">
        <div class="wb-brand">
            <span class="wb-brand-name">ClaudeWorkbench</span>
            <span class="wb-brand-tag">operator console</span>
        </div>
        <div class="wb-status">
            <span class="wb-dot @(Stream.Connected ? "up" : "down")"></span>
            <span>@(Stream.Connected ? "sidecar connected" : "sidecar offline")</span>
            @if (Stream.ActiveTurn is not null)
            {
                <span class="wb-live">· working</span>
            }
        </div>
    </header>

    <main class="wb-main">
        <RadzenTabs RenderMode="TabRenderMode.Client">
            <Tabs>
                <RadzenTabsItem Text="Assistant">
                    <AssistantTab />
                </RadzenTabsItem>
                <RadzenTabsItem Text="@($"Approvals ({Stream.PendingGates().Count})")">
                    <ApprovalsTab />
                </RadzenTabsItem>
                <RadzenTabsItem Text="Activity">
                    <ActivityTab />
                </RadzenTabsItem>
            </Tabs>
        </RadzenTabs>
    </main>
</div>

@code {
    protected override void OnInitialized()
    {
        Stream.Changed += OnChanged;
    }

    private void OnChanged()
    {
        InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        Stream.Changed -= OnChanged;
    }
}
