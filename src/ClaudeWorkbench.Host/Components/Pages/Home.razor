@page "/"

@* Faithful Coding Services shell (command bar + work panel + RadzenTabs), ported
   from CodexAppServerDemo. Binds only to IOperatorConsole — no sidecar/Claude
   types reach the UI. Branding: the Coding Services logo + the "Powered by
   Coding Services" line beside ClaudeWorkbench. *@

@if (!Workspace.HasWorkspace)
{
    <WorkspacePicker Embedded="true" OnClose="@CloseWorkspacePicker" />
}
else
{
<section class="control-screen">
    <header class="command-bar">
        <div class="title-strip">
            <div class="brand-lockup">
                <img class="brand-logo" src="images/cs_header_logo_56x40.svg" alt="Coding Services" />
                <div class="brand-text">
                    <h1>ClaudeWorkbench</h1>
                    <div class="brand-tagline">Powered by Coding Services</div>
                </div>
            </div>
        </div>
        <div class="command-bar-actions">
            <span class="wb-status">
                <span class="wb-dot @(Session.Status.Connected ? "up" : "down")"></span>
                @(Session.Status.Connected ? "Claude available" : "Claude unavailable")
            </span>
            <RadzenButton Icon="settings"
                          Text="Settings"
                          ButtonStyle="ButtonStyle.Light"
                          Size="ButtonSize.Small"
                          Click="@(() => settingsOpen = true)" />
        </div>
    </header>

    <main class="control-grid">
        <section class="work-panel">
            <div class="workspace-toolbar">
                <div class="workspace-path">
                    <strong>@Session.WorkspacePath</strong>
                </div>
                <div class="workspace-state">
                    @if (Session.Status.Working)
                    {
                        <span class="workspace-state-text workspace-state-text-live">
                            <span class="workspace-state-spinner" aria-hidden="true"></span>
                            <span>Thinking</span>
                        </span>
                    }
                    else
                    {
                        <span class="workspace-state-text">Ready</span>
                    }
                </div>
                <RadzenButton Icon="folder_open"
                              Text="Change"
                              ButtonStyle="ButtonStyle.Light"
                              Size="ButtonSize.Small"
                              Title="Switch watched solution"
                              Click="@(() => workspacePickerOpen = true)" />
            </div>

            <RadzenTabs RenderMode="TabRenderMode.Client">
                <Tabs>
                    <RadzenTabsItem Text="Assistant">
                        <AssistantTab />
                    </RadzenTabsItem>
                    <RadzenTabsItem Text="@($"Approvals ({Approvals.PendingApprovals.Count})")">
                        <ApprovalsTab />
                    </RadzenTabsItem>
                    <RadzenTabsItem Text="Source">
                        <SourcePanel />
                    </RadzenTabsItem>
                    <RadzenTabsItem Text="Activity">
                        <ActivityTab />
                    </RadzenTabsItem>
                </Tabs>
            </RadzenTabs>
        </section>
    </main>

    <AgentSettingsDialog Visible="@settingsOpen" OnClose="@(() => settingsOpen = false)" />

    @if (workspacePickerOpen)
    {
        <WorkspacePicker Embedded="false" OnClose="@CloseWorkspacePicker" />
    }
</section>
}
