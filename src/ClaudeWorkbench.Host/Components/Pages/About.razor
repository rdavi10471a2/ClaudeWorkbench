@page "/about"

@*  Fun "About" page — just the poster, centered full-screen. Self-contained (this one
    file + wwwroot/images/about-poster.png). To disable later: delete this file and
    remove the "About" link in Home.razor. Classes are ab- prefixed so nothing leaks.  *@

<div class="ab-root">
    <a class="ab-back" href="/">&larr;&nbsp;Workbench</a>
    <img class="ab-poster"
         src="images/about-poster.png"
         alt="What is best in life? — ClaudeWorkbench, governed barbarian" />
</div>

<style>
    .ab-root {
        position: relative;
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 24px;
        background: #0d0b09;
    }

    .ab-back {
        position: fixed;
        top: 16px;
        left: 16px;
        z-index: 5;
        font-family: system-ui, -apple-system, "Segoe UI", sans-serif;
        font-size: 0.78rem;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: #cbb189;
        text-decoration: none;
        padding: 6px 12px;
        border: 1px solid rgba(203, 162, 75, 0.4);
        border-radius: 999px;
        background: rgba(0, 0, 0, 0.45);
    }

    .ab-back:hover {
        color: #ffffff;
        border-color: #db4b2b;
    }

    .ab-back:focus-visible {
        outline: 2px solid #7bb7b0;
        outline-offset: 2px;
    }

    .ab-poster {
        max-width: 100%;
        max-height: calc(100vh - 48px);
        width: auto;
        height: auto;
        border-radius: 6px;
        box-shadow: 0 20px 60px rgba(0, 0, 0, 0.7);
    }
</style>
