@{
    // Snapshot once per render: these are recomputed properties over live gate
    // state, so a gate resolving mid-render would otherwise flip them to null
    // between the guard and the field access -> NRE that tears down the circuit.
    ApprovalRequest? approval = CurrentApproval;
    Elicitation? elicitation = approval is null ? CurrentElicitation : null;
}
@if (approval is not null)
{
    <div class="agent-modal-overlay" role="dialog" aria-modal="true" aria-label="Agent action required">
        <section class="agent-modal-card">
            <div class="agent-modal-header">
                <div>
                    <span class="agent-modal-eyebrow">Input Required</span>
                    <h3>@approval.Title</h3>
                    <code class="agent-modal-tool-badge">@approval.Tool</code>
                </div>
                <div class="agent-modal-status">Waiting for you</div>
            </div>
            <div class="agent-modal-body action-mode">
                <section class="agent-modal-main">
                    @foreach (ApprovalDetail detail in approval.Details)
                    {
                        <div class="agent-modal-section">
                            <span class="agent-modal-label">@detail.Label</span>
                            @if (detail.IsCode)
                            {
                                <pre class="agent-modal-payload-box">@detail.Value</pre>
                            }
                            else
                            {
                                <code>@detail.Value</code>
                            }
                        </div>
                    }
                    @if (!string.IsNullOrWhiteSpace(approval.InputJson))
                    {
                        <details class="agent-modal-raw">
                            <summary>Raw request</summary>
                            <pre class="agent-modal-payload-box">@approval.InputJson</pre>
                        </details>
                    }
                </section>
            </div>
            <div class="agent-modal-footer">
                @if (CanRemember(approval.Tool))
                {
                    <p class="agent-modal-remember-warning">
                        &#9888; "Allow all @approval.Tool" lets it run for the rest of this thread without asking — <strong>any arguments</strong>. Reset on New Thread.
                    </p>
                }
                <RadzenButton Text="Allow"
                              ButtonStyle="ButtonStyle.Success"
                              Size="ButtonSize.Small"
                              Title="Allow this one call"
                              Click="@(() => ResolveApprovalAsync(true))" />
                @if (CanRemember(approval.Tool))
                {
                    <RadzenButton Text="@($"Allow all {approval.Tool} this thread")"
                                  ButtonStyle="ButtonStyle.Warning"
                                  Size="ButtonSize.Small"
                                  Title="@($"Every {approval.Tool} call runs without asking for the rest of this thread, regardless of arguments (reset on New Thread).")"
                                  Click="@(() => ResolveApprovalAsync(true, remember: true))" />
                }
                <RadzenButton Text="Deny"
                              ButtonStyle="ButtonStyle.Light"
                              Size="ButtonSize.Small"
                              Click="@(() => ResolveApprovalAsync(false))" />
            </div>
        </section>
    </div>
}
else if (elicitation is not null)
{
    <div class="agent-modal-overlay" role="dialog" aria-modal="true" aria-label="Input requested">
        <section class="agent-modal-card">
            <div class="agent-modal-header">
                <div>
                    <span class="agent-modal-eyebrow">Input Requested</span>
                    <h3>Answer to continue</h3>
                </div>
                <div class="agent-modal-status">Waiting for you</div>
            </div>
            <div class="agent-modal-body action-mode">
                <section class="agent-modal-main">
                    @if (elicitation.Questions.Count > 1)
                    {
                        <div class="agent-modal-qtabs" role="tablist">
                            @for (int index = 0; index < elicitation.Questions.Count; index++)
                            {
                                int tabIndex = index;
                                <button type="button"
                                        class="agent-modal-qtab @(ActiveQuestion == tabIndex ? "active" : string.Empty) @(IsAnswered(elicitation.Questions[tabIndex]) ? "answered" : string.Empty)"
                                        @onclick="@(() => ActiveQuestion = tabIndex)">
                                    @elicitation.Questions[tabIndex].Header
                                </button>
                            }
                        </div>
                    }

                    @if (elicitation.Questions.Count > 0)
                    {
                        ElicitationQuestion question = elicitation.Questions[Math.Clamp(ActiveQuestion, 0, elicitation.Questions.Count - 1)];
                        <div class="agent-modal-question">
                            <div class="agent-modal-question-title">@question.Question</div>
                            @if (question.MultiSelect)
                            {
                                <small class="agent-modal-question-hint">Select all that apply.</small>
                            }
                            <div class="agent-modal-choice-list">
                                @foreach (ElicitationOption option in question.Options)
                                {
                                    <button type="button"
                                            class="agent-modal-choice-card @(IsChosen(question.Question, option.Label) ? "selected" : string.Empty)"
                                            @onclick="@(() => Choose(question.Question, option.Label, question.MultiSelect))">
                                        <strong>@option.Label</strong>
                                        @if (!string.IsNullOrWhiteSpace(option.Description))
                                        {
                                            <small>@option.Description</small>
                                        }
                                    </button>
                                }
                            </div>
                            <input class="agent-modal-other-input"
                                   type="text"
                                   placeholder="Other — type your own answer"
                                   value="@GetOther(question.Question)"
                                   @onfocus="@(() => BeginOther(question.Question))"
                                   @oninput="@(args => SetOther(question.Question, args.Value?.ToString()))" />
                        </div>
                    }
                </section>
            </div>
            <div class="agent-modal-footer">
                <RadzenButton Text="Submit Answer"
                              ButtonStyle="ButtonStyle.Success"
                              Size="ButtonSize.Small"
                              Click="@SubmitElicitationAsync" />
            </div>
        </section>
    </div>
}
